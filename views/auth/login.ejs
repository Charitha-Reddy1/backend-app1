<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <style>

body{

    background:#f1f5f9;

    font-family:Arial, sans-serif;
}

.login-container{

    max-width:400px;

    margin:80px auto;

    background:white;

    padding:35px;

    border-radius:16px;

    box-shadow:
    0 4px 14px rgba(0,0,0,0.12);

    text-align:center;
}

.login-title{

    margin-bottom:25px;

    color:#1e293b;

    font-size:30px;
}

.login-form input{

    width:100%;

    padding:12px;

    margin-bottom:18px;

    border:1px solid #cbd5e1;

    border-radius:8px;

    font-size:15px;

    box-sizing:border-box;

    outline:none;

    transition:0.3s;
}

.login-form input:focus{

    border-color:#2563eb;

    box-shadow:
    0 0 5px rgba(37,99,235,0.3);
}

.login-form button{

    width:100%;

    padding:12px;

    border:none;

    border-radius:8px;

    background:#2563eb;

    color:white;

    font-size:16px;

    font-weight:bold;

    cursor:pointer;

    transition:0.3s;
}

.login-form button:hover{

    background:#1d4ed8;
}

.register-link{

    margin-top:18px;

    font-size:15px;
}

.register-link a{

    color:#16a34a;

    text-decoration:none;

    font-weight:bold;
}

.register-link a:hover{

    text-decoration:underline;
}

    </style>

</head>

<body>

    <div class="login-container">

        <h2 class="login-title">
            Login Form
        </h2>

        <form
          action="/auth/login"
          method="POST"
          class="login-form"
        >

            <p>
                <input
                  type="text"
                  name="email"
                  placeholder="Email"
                >
            </p>

            <p>
                <input
                  type="password"
                  name="password"
                  placeholder="Password"
                >
            </p>

            <p>
                <button>
                    Login
                </button>
            </p>

        </form>

        <p class="register-link">

            <a href="/auth/register">
                New User? Register Here !!
            </a>

        </p>

    </div>

</body>
</html>