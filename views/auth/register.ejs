<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>

    <style>

body{

    background:#f1f5f9;

    font-family:Arial, sans-serif;
}

.register-container{

    max-width:400px;

    margin:80px auto;

    background:white;

    padding:35px;

    border-radius:16px;

    box-shadow:
    0 4px 14px rgba(0,0,0,0.12);

    text-align:center;
}

.register-title{

    margin-bottom:25px;

    color:#1e293b;

    font-size:30px;
}

.register-form input{

    width:100%;

    padding:12px;

    margin-bottom:18px;

    border:1px solid #cbd5e1;

    border-radius:8px;

    font-size:15px;

    box-sizing:border-box;

    outline:none;

    transition:0.3s;
}

.register-form input:focus{

    border-color:#16a34a;

    box-shadow:
    0 0 5px rgba(22,163,74,0.3);
}

.register-form button{

    width:100%;

    padding:12px;

    border:none;

    border-radius:8px;

    background:#16a34a;

    color:white;

    font-size:16px;

    font-weight:bold;

    cursor:pointer;

    transition:0.3s;
}

.register-form button:hover{

    background:#15803d;
}

.login-link{

    margin-top:18px;

    font-size:15px;
}

.login-link a{

    color:#2563eb;

    text-decoration:none;

    font-weight:bold;
}

.login-link a:hover{

    text-decoration:underline;
}

    </style>

</head>

<body>

    <div class="register-container">

        <h2 class="register-title">
            Registration Form
        </h2>

        <form
          action="/auth/register"
          method="POST"
          class="register-form"
        >

            <p>
                <input
                  type="text"
                  name="name"
                  placeholder="Name"
                >
            </p>

            <p>
                <input
                  type="text"
                  name="email"
                  placeholder="Email"
                >
            </p>

            <p>
                <input
                  type="password"
                  name="password"
                  placeholder="Password"
                >
            </p>

            <p>
                <button>
                    Submit
                </button>
            </p>

        </form>

        <p class="login-link">

            <a href="/auth/login">
                Already a member? Login here
            </a>

        </p>

    </div>

</body>
</html>